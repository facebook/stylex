    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@stylexjs/eslint-plugin": "0.18.2",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^16.4.0",
    "svelte": "^5.53.5",
    "svelte-check": "^4.3.4",
    "shx": "^0.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.2.6",
    "@stylexjs/unplugin": "0.18.2",
    "eslint": "^8.57.1"
  }
