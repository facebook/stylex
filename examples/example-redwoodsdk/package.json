{
  "name": "@redwoodjs/starter",
  "version": "0.19.0",
  "description": "A bare-bones RedwoodSDK starter",
  "main": "index.js",
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "MIT",
  "private": true,
  "scripts": {
    "example:build": "vite build",
    "example:dev": "vite dev",
    "dev:init": "rw-scripts dev-init",
    "example:serve": "vite preview",
    "worker:run": "rw-scripts worker-run",
    "clean": "npm run clean:vite",
    "clean:vite": "shx rm -rf ./node_modules/.vite",
    "release": "rw-scripts ensure-deploy-env && npm run clean && npm run example:build && wrangler deploy",
    "generate": "rw-scripts ensure-env && wrangler types --include-runtime false",
    "check": "npm run generate && npm run types",
    "types": "tsc"
  },
  "dependencies": {
    "@stylexjs/stylex": "0.19.0",
    "capnweb": "~0.8.0",
    "react": "19.3.0-canary-56824423-20260414",
    "react-dom": "19.3.0-canary-56824423-20260414",
    "react-server-dom-webpack": "19.2.7",
    "rwsdk": "1.3.0",
    "@stylexjs/shared-ui": "0.19.0"
  },
  "devDependencies": {
    "@stylexjs/eslint-plugin": "0.19.0",
    "@stylexjs/unplugin": "0.19.0",
    "@typescript-eslint/parser": "^8.58.2",
    "@cloudflare/vite-plugin": "^1.15.2",
    "@cloudflare/workers-types": "^4.20260120.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.5.0",
    "shx": "^0.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.50.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
